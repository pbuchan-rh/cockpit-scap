Name: cockpit-scap
Version: %{VERSION}
Release: 1%{?dist}
Summary: Cockpit UI for SCAP security compliance scanning
License: LGPL-2.1-or-later

# distributions which ship nodejs-esbuild can rebuild the bundle during package build
%if 0%{?fedora} >= 42
%define rebuild_bundle 1
%endif

Source0: https://github.com/pbuchan-rh/cockpit-scap/releases/download/%{version}/%{name}-%{version}.tar.xz
Source1: https://github.com/pbuchan-rh/cockpit-scap/releases/download/%{version}/%{name}-node-%{version}.tar.xz

BuildArch: noarch
%if ! 0%{?suse_version}
ExclusiveArch: %{nodejs_arches} noarch
%endif
BuildRequires: make
BuildRequires: gettext
%if %{defined rebuild_bundle}
BuildRequires: /usr/bin/node
BuildRequires: nodejs-esbuild
%endif

Requires: cockpit-bridge
Requires: openscap-scanner

%{NPM_PROVIDES}

%description
Provides a Cockpit interface for running SCAP security compliance scans using
OpenSCAP. Detects installed SCAP Security Guide content, lets you choose a
profile, runs oscap, and shows the compliance score and failing rules with
options to download remediation scripts or the full HTML report.

%prep
%autosetup -n %{name}
%if %{defined rebuild_bundle}
%setup -q -D -T -a 1 -n %{name}
%endif

%build
%if %{defined rebuild_bundle}
rm -rf dist
NODE_ENV=production NODE_PATH=/usr/lib/node_modules:$(echo /usr/lib/node_modules_*) ./build.js
%else
# Use pre-built bundle on distributions without nodejs-esbuild
%endif

%install
%make_install PREFIX=/usr

# drop source maps
find %{buildroot}%{_datadir}/cockpit/ -name '*.map' | xargs --no-run-if-empty rm --verbose

%files
%doc README.md
%license LICENSE dist/index.js.LEGAL.txt
%{_datadir}/cockpit/*

%changelog
